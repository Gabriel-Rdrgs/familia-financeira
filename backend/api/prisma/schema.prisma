generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Pessoa {
  id                Int               @id @default(autoincrement())
  nome              String
  papelNaFamilia    PapelNaFamilia
  tipoRendaPrincipal TipoRenda
  ativo             Boolean           @default(true)

  contas            ContaFinanceira[]
  transacoes        Transacao[]       @relation("TransacoesPessoaResponsavel")
  dividas           Divida[]
}

model ContaFinanceira {
  id              Int              @id @default(autoincrement())
  nome            String
  tipo            TipoConta
  limite          Float?
  ativo           Boolean          @default(true)

  titularPessoaId Int?
  titularPessoa   Pessoa?          @relation(fields: [titularPessoaId], references: [id])

  transacoesOrigem  Transacao[]    @relation("TransacoesContaOrigem")
  transacoesDestino Transacao[]    @relation("TransacoesContaDestino")
  investimentos     Investimento[]
}

model Categoria {
  id          Int           @id @default(autoincrement())
  nome        String
  tipoFluxo   TipoFluxo
  prioridade  Prioridade

  subcategorias Subcategoria[]
  transacoes    Transacao[]
}

model Subcategoria {
  id          Int           @id @default(autoincrement())
  nome        String

  categoriaId Int
  categoria   Categoria     @relation(fields: [categoriaId], references: [id])

  transacoes  Transacao[]
}

model Meta {
  id             Int          @id @default(autoincrement())
  nome           String
  tipo           TipoMeta
  valorAlvo      Float
  valorAcumulado Float        @default(0)
  dataInicio     DateTime     @default(now())
  dataMeta       DateTime?
  ativa          Boolean      @default(true)

  transacoes     Transacao[]
  investimentos  Investimento[]
}

model Investimento {
  id                  Int          @id @default(autoincrement())
  tipoProduto         TipoProdutoInvestimento
  instituicao         String
  dataAplicacao       DateTime
  valorAplicado       Float
  valorAtual          Float        @default(0)
  liquidez            Liquidez

  metaId              Int?
  meta                Meta?        @relation(fields: [metaId], references: [id])

  contaInvestimentoId Int
  contaInvestimento   ContaFinanceira @relation(fields: [contaInvestimentoId], references: [id])
}

model Negocio {
  id                Int          @id @default(autoincrement())
  nome              String
  tipo              TipoNegocio
  ativo             Boolean      @default(true)
  descricao         String?
  dataInicioPrevista DateTime?
  dataInicioReal    DateTime?

  transacoes        Transacao[]
}

// ─── DÍVIDAS ────────────────────────────────────────────────────────────────

model Divida {
  id               Int           @id @default(autoincrement())
  credor           String        // "Serasa - Nubank", "Claro", etc.
  descricao        String?       // observações livres
  valorOriginal    Float         // quanto devia antes de negociar
  valorNegociado   Float         // quanto ficou após desconto/acordo
  totalParcelas    Int           // número total de parcelas
  valorParcela     Float         // valor fixo de cada parcela
  diaVencimento    Int           // dia do mês (1-31)
  dataInicio       DateTime      // data da primeira parcela
  status           StatusDivida  @default(ATIVA)

  // relação opcional com pessoa responsável
  pessoaId         Int?
  pessoa           Pessoa?       @relation(fields: [pessoaId], references: [id])

  parcelas         ParcelaDivida[]

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model ParcelaDivida {
  id               Int           @id @default(autoincrement())
  numeroParcela    Int           // 1, 2, 3...
  dataVencimento   DateTime
  valorPrevisto    Float
  valorPago        Float?        // null = não paga ainda
  dataPagamento    DateTime?     // null = não paga ainda
  status           StatusParcela @default(PENDENTE)
  observacao       String?

  dividaId         Int
  divida           Divida        @relation(fields: [dividaId], references: [id], onDelete: Cascade)

  // opcional: vincular ao lançamento real de transação
  transacaoId      Int?          @unique

  createdAt        DateTime      @default(now())
}

// ─── ENUMS ──────────────────────────────────────────────────────────────────

enum PapelNaFamilia {
  PAI
  MAE
  FILHO
  FILHA
  OUTRO
}

enum TipoRenda {
  CLT
  AUTONOMO
  ESTAGIARIO
  APOSENTADO
  SEM_RENDA
}

enum TipoConta {
  CONTA_CORRENTE
  CARTEIRA
  CARTAO_CREDITO
  POUPANCA
  CONTA_INVESTIMENTO
}

enum TipoFluxo {
  RECEITA
  DESPESA
  AMBOS
}

enum Prioridade {
  ALTA
  MEDIA
  BAIXA
}

enum TipoMeta {
  SAUDE
  DIVIDA
  RESERVA
  NEGOCIO
  LAZER
  OUTRO
}

enum TipoProdutoInvestimento {
  TESOURO_SELIC
  CDB_LIQUIDEZ_DIARIA
  CDB_LONGO_PRAZO
  TESOURO_IPCA
  LCI_LCA
  FUNDO
  OUTRO
}

enum Liquidez {
  D_PLUS_0
  D_PLUS_1
  D_PLUS_30
  VENCIMENTO
}

enum TipoNegocio {
  LANCHONETE
  OUTRO
}

enum TipoTransacao {
  RECEITA
  DESPESA
  TRANSFERENCIA
}

enum FormaPagamento {
  DINHEIRO
  DEBITO
  CREDITO
  PIX
  BOLETO
  OUTRO
}

enum StatusDivida {
  ATIVA
  QUITADA
  RENEGOCIADA
  SUSPENSA
}

enum StatusParcela {
  PENDENTE
  PAGA
  ATRASADA
  IGNORADA
}
